# Pipeline-specific commands (Garmin / banking / landing-zone).
# Reachable from devserver root via `just pipelines <recipe>` (mod import) or
# directly with `cd pipelines && just <recipe>`.
#
# Secret rendering (`just rs`) lives in the devserver root Justfile — it renders
# ALL config/*.tmpl, not just pipeline ones.

set shell := ["bash", "-euo", "pipefail", "-c"]

# Compose file lives at the devserver root, one level up from here.
PIPELINES := "docker compose -f ../docker-compose.pipelines.yml"

pipelines-up *args:
  {{PIPELINES}} up -d {{args}}

pipelines-down *args:
  {{PIPELINES}} down {{args}}

pipelines-build *args:
  {{PIPELINES}} build {{args}}

pipelines-logs *args:
  {{PIPELINES}} logs -f {{args}}

up-dbos: (pipelines-up "mock-bank" "pipeline-dbos")
up-dagster: (pipelines-up "mock-bank" "pipeline-dagster")
up-restate: (pipelines-up "mock-bank" "restate-server" "pipeline-restate")

# Register the Restate SDK app with the Restate server (re-run after rebuild)
restate-register:
  curl -s -X POST http://localhost:18803/deployments \
    -H 'content-type: application/json' \
    -d '{"uri":"http://pipeline-restate:9080","force":true}' \
    | head -c 200; echo

# Read the most-recent generated OTP from the mock bank
mock-otp:
  @docker exec mock-bank python3 -c \
    "import urllib.request; print(urllib.request.urlopen('http://localhost:8000/current_otp').read().decode())"

# Seed a pipeline DB's raw_responses from the source garmin DB
pipeline-seed pipeline="dbos" start="2026-01-01" end="2026-05-18":
  docker exec pipeline-{{pipeline}} bash -lc \
    "cd /app/shared && uv run pipeline-shared seed --start {{start}} --end {{end}}"

pipeline-status pipeline="dbos":
  docker exec pipeline-{{pipeline}} bash -lc \
    "cd /app/shared && uv run pipeline-shared status"

# Reparse a single date for any pipeline
pipeline-reparse pipeline="dbos" date="2026-05-15":
  docker exec pipeline-{{pipeline}} bash -lc \
    "cd /app/shared && uv run pipeline-shared reparse {{date}}"

# Force a live Garmin re-fetch for a date range (default: just <start>).
# Unlike reparse (cache-only) and asset materialization (forces today+yesterday
# only), this bypasses the cache and overwrites stale/empty stubs with fresh
# API data for ANY past day — use after a device-sync gap. Needs GARMIN_LIVE_FETCH.
#   just pipelines garmin-refetch 2026-06-02
#   just pipelines garmin-refetch 2026-06-02 2026-06-04
garmin-refetch start end="" pipeline="dagster":
  docker exec pipeline-{{pipeline}} bash -lc \
    "cd /app/shared && uv run pipeline-shared refetch {{start}} {{end}}"

# Heal gaps: refetch ONLY days in the last <window> still missing sleep data.
# Same logic the daily garmin_heal_schedule runs; this is the manual trigger.
#   just pipelines garmin-heal          # last 10 days
#   just pipelines garmin-heal 14
garmin-heal window="10" pipeline="dagster":
  docker exec pipeline-{{pipeline}} bash -lc \
    "cd /app/shared && uv run pipeline-shared heal --window {{window}}"

# Trigger a bank import end-to-end for a given pipeline. The pipeline-specific
# approval URL is printed; supply the OTP from `just mock-otp` to complete.
bank-import-dbos:
  @curl -s -X POST http://localhost:18801/trigger/bank_import \
    -d 'bank_name=mock-bank&username=ankit&password=test'
  @echo "  → approve at http://localhost:18801/approve?wf=<workflow_id from response>"

bank-import-dagster:
  @docker exec pipeline-dagster bash -lc \
    "cd /app/dagster && uv run dagster job launch -j bank_login_job -m pipeline_dagster_proj.definitions" | tail -3
  @echo "  → fill OTP in bank_pending: UPDATE bank_pending SET otp=<otp> WHERE id=<latest>"
  @echo "  → sensor will fire bank_resume_job within 3s"

bank-import-restate:
  @WF_ID=$(python3 -c 'import uuid; print(uuid.uuid4())'); \
    echo "wf=$WF_ID"; \
    curl -s -X POST "http://localhost:18883/BankImport/$WF_ID/run/send" \
      -H 'content-type: application/json' \
      -d '{"bank_name":"mock-bank","username":"ankit","password":"test"}'
  @echo
  @echo "  → approval url printed in notifications table (kind='bank:otp_required')"

# ── landing_zone (file-drop pipelines) ────────────────────────────
# Host path of the landing zone — the network mount bound into pipeline-dagster
# at /landing_zone. Clients on other machines write here directly.
LANDING_ZONE := "/mnt/synologydrive/docs-root/projects/data-dropbox"

# Drop one or more files into <LANDING_ZONE>/<pipeline>/<batch-id>/ following
# the contract (see the dropbox README.md): .tmp during write, _READY last.
# Usage:
#   just pipelines lz-drop playnite-gameactivity 2026-05-19-host1 file1.json file2.json
lz-drop pipeline batch_id +files:
  #!/usr/bin/env -S uv run --quiet python3
  import shutil, sys
  from pathlib import Path

  root = Path("{{LANDING_ZONE}}") / "{{pipeline}}" / "{{batch_id}}"
  if root.exists():
      sys.exit(f"refusing to drop into existing dir {root}")
  root.mkdir(parents=True)
  for src_str in """{{files}}""".split():
      src = Path(src_str)
      if not src.is_file():
          sys.exit(f"not a file: {src}")
      tmp = root / (src.name + ".tmp")
      shutil.copy2(src, tmp)
      tmp.rename(root / src.name)
      print(f"  + {src.name}")
  (root / "_READY").write_bytes(b"")
  print(f"ready: {root}")

# Run landing-zone GC now (prune >30d archives, sweep >14d failed batches).
# The same logic runs daily via the landing_zone_gc_schedule.
lz-gc:
  @docker exec pipeline-dagster bash -lc \
    "cd /app/dagster && uv run dagster job launch -j landing_zone_gc_job -m pipeline_dagster_proj.definitions" | tail -3

# Import latest stories/comments for HN_USERNAMES from ClickHouse's updating
# hackernews_history dataset into Postgres table hn_user_items.
hn-import:
  @docker exec pipeline-dagster bash -lc \
    "cd /app/dagster && uv run dagster job launch -j hackernews_user_items_import_job -m pipeline_dagster_proj.definitions" | tail -3

# List ready (un-archived) batches + last 20 entries in the batch ledger.
lz-status:
  @echo "=== ready (pre-archive) ==="
  @find {{LANDING_ZONE}} -mindepth 3 -maxdepth 3 -name _READY 2>/dev/null \
    | sed 's|/_READY$||; s|^{{LANDING_ZONE}}/||' | sort || true
  @echo
  @echo "=== landing_zone_batches (last 20) ==="
  @docker exec postgres psql -U garmin -d pipeline_dagster -c \
    "SELECT pipeline, batch_id, status, file_count, row_count, \
            EXTRACT(EPOCH FROM (finished_at - started_at))::int AS dur_s, \
            COALESCE(error, '') AS error \
       FROM landing_zone_batches \
      ORDER BY COALESCE(finished_at, started_at, ready_at) DESC LIMIT 20;"

{
  "$schema": "https://www.getbifrost.ai/schema",

  "client": {
    "drop_excess_requests": false,
    "prometheus_labels": ["model", "provider"]
  },

  "config_store": {
    "enabled": true,
    "type": "sqlite",
    "config": {
      "path": "/app/data/config.db"
    }
  },

  "logs_store": {
    "enabled": true,
    "type": "sqlite",
    "config": {
      "path": "/app/data/logs.db"
    }
  },

  "mcp": {
    "client_configs": [
      {
        "name": "mcpproxy",
        "connection_type": "http",
        "connection_string": "http://172.19.0.1:3130/mcp/all",
        "is_ping_available": false,
        "auth_type": "headers",
        "headers": {
          "Authorization": "Bearer {{ op://clankers/mcpproxy-agents/password }}"
        },
        "tools_to_execute": ["*"],
        "tools_to_auto_execute": [
          "exa__web_search_exa",
          "exa__web_search_advanced_exa",
          "exa__web_fetch_exa"
        ],
        "allow_on_all_virtual_keys": true
      }
    ]
  },

  "plugins": [
    {
      "enabled": true,
      "name": "model-policy-suffix",
      "path": "/app/plugins/model-policy-suffix.so",
      "version": 1
    }
  ],

  "providers": {
    "openrouter": {
      "keys": [
        {
          "name": "openrouter-key-1",
          "value": "env.OPENROUTER_API_KEY",
          "models": ["*"],
          "weight": 1.0
        }
      ],
      "network_config": {
        "base_url": "https://openrouter.ai/api",
        "default_request_timeout_in_seconds": 120,
        "extra_headers": {
          "HTTP-Referer": "https://dev.ankitson.com",
          "X-Title": "bifrost-devserver"
        }
      }
    },

    "anthropic": {
      "keys": [
        {
          "name": "anthropic-key-1",
          "value": "env.ANTHROPIC_API_KEY",
          "models": ["*"],
          "weight": 1.0
        }
      ]
    },

    "openai": {
      "keys": [
        {
          "name": "openai-key-1",
          "value": "env.OPENAI_API_KEY",
          "models": ["*"],
          "weight": 1.0
        }
      ]
    },

    "codex": {
      "keys": [
        {
          "name": "codex-oauth-noauth",
          "value": "env.CODEX_PROXY_API_KEY",
          "models": ["*"],
          "weight": 1.0
        }
      ],
      "network_config": {
        "base_url": "http://codex-oauth:10531",
        "default_request_timeout_in_seconds": 600,
        "stream_idle_timeout_in_seconds": 300,
        "allow_private_network": true
      },
      "custom_provider_config": {
        "base_provider_type": "openai",
        "allowed_requests": {
          "list_models": true,
          "chat_completion": true,
          "chat_completion_stream": true,
          "responses": true,
          "responses_stream": true
        }
      }
    },

    "nvidia": {
      "keys": [
        {
          "name": "nvidia-build-key-1",
          "value": "env.NVIDIA_API_KEY",
          "models": [
            "meta/llama-3.1-8b-instruct",
            "nvidia/llama-3.1-nemotron-nano-8b-v1",
            "nvidia/nvidia-nemotron-nano-9b-v2",
            "nvidia/llama-3.3-nemotron-super-49b-v1.5",
            "mistralai/mistral-small-4-119b-2603"
          ],
          "weight": 1.0
        }
      ],
      "network_config": {
        "base_url": "https://integrate.api.nvidia.com",
        "default_request_timeout_in_seconds": 120
      },
      "custom_provider_config": {
        "base_provider_type": "openai",
        "allowed_requests": {
          "chat_completion": true,
          "chat_completion_stream": true,
          "embedding": true
        }
      }
    },

    "deepseek": {
      "keys": [
        {
          "name": "deepseek-key-1",
          "value": "env.DEEPSEEK_API_KEY",
          "models": ["*"],
          "weight": 1.0
        }
      ],
      "network_config": {
        "base_url": "https://api.deepseek.com",
        "default_request_timeout_in_seconds": 120
      },
      "custom_provider_config": {
        "base_provider_type": "openai",
        "allowed_requests": {
          "chat_completion": true,
          "chat_completion_stream": true
        }
      }
    },

    "unsloth": {
      "keys": [
        {
          "name": "unsloth-studio-key-1",
          "value": "env.UNSLOTH_STUDIO_API_KEY",
          "models": ["default"],
          "weight": 1.0
        }
      ],
      "network_config": {
        "base_url": "http://desktop-win:8888",
        "default_request_timeout_in_seconds": 600,
        "stream_idle_timeout_in_seconds": 300,
        "allow_private_network": true
      },
      "custom_provider_config": {
        "base_provider_type": "openai",
        "allowed_requests": {
          "list_models": true,
          "chat_completion": true,
          "chat_completion_stream": true,
          "text_completion": true,
          "text_completion_stream": true,
          "responses": true,
          "responses_stream": true,
          "embedding": true
        }
      }
    },

    "speaches": {
      "keys": [
        {
          "name": "speaches-noauth",
          "value": "env.SPEACHES_API_KEY",
          "models": ["deepdml/faster-whisper-large-v3-turbo-ct2"],
          "weight": 1.0
        }
      ],
      "network_config": {
        "base_url": "http://speaches:8000",
        "default_request_timeout_in_seconds": 120,
        "allow_private_network": true
      },
      "custom_provider_config": {
        "base_provider_type": "openai",
        "allowed_requests": {
          "transcription": true,
          "transcription_stream": true,
          "speech": true
        }
      }
    }
  }
}

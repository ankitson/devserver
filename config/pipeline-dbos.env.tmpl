# Rendered to ../secrets/pipeline-dbos.env via `just rs`.
DATABASE_URL=postgresql://garmin:{{ op://clankers/local-service/password }}@postgres:5432/pipeline_dbos
GARMIN_SOURCE_DATABASE_URL=postgresql://garmin:{{ op://clankers/local-service/password }}@postgres:5432/garmin

# Live Garmin fetching is intentionally OFF by default. Reparse-from-cache
# is the safe path. Flip to true only when you actually want API traffic.
GARMIN_LIVE_FETCH=false
GARMIN_MIN_REQUEST_INTERVAL_SECONDS=2.5
GARMIN_EMAIL=
GARMIN_PASSWORD=

MOCK_BANK_URL=http://mock-bank:8000
HEADLESS_BROWSER=true

# ntfy (optional — leave NTFY_TOPIC blank to disable phone push)
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=
NTFY_TOKEN=

# OpenClaw env — rendered to secrets/openclaw.env by `just rs` (op inject).
# Consumed by: the openclaw container (sourced in entrypoint) and the
# openclaw-browser sidecar (env_file).

# ── gateway / paths (non-secret) ───────────────────────────────────
OPENCLAW_CONFIG_DIR=/home/ankit/.openclaw
OPENCLAW_STATE_DIR=/home/ankit/.openclaw
OPENCLAW_WORKSPACE_DIR=/home/ankit/.openclaw/workspace
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_BIND=lan

# ── provider keys (reuse existing vault items from hermes.env.tmpl) ──
ANTHROPIC_API_KEY={{ op://clankers/anthropic-key1/password }}
OPENAI_API_KEY={{ op://clankers/openai/password }}
OPENROUTER_API_KEY={{ op://clankers/openrouter/password }}
GEMINI_API_KEY={{ op://clankers/google-gemini/password }}
OPENCODE_API_KEY={{ op://clankers/opencode-zen/password }}
DEEPSEEK_API_KEY={{ op://clankers/deepseek/password }}
BRAVE_API_KEY={{ op://clankers/brave/password }}
# EXA_API_KEY={{ op://clankers/exa/password }}   # uncomment once you create the 1Password item

# ── MCP gateway (mcpproxy) ─────────────────────────────────────────
# Scoped downstream agent token for the shared mcpproxy MCP gateway. Referenced
# as ${MCPPROXY_AGENT_TOKEN} by openclaw.json's mcp.servers.mcpproxy header.
MCPPROXY_AGENT_TOKEN={{ op://clankers/mcpproxy-agents/password }}

# ── channels ───────────────────────────────────────────────────────
DISCORD_BOT_TOKEN={{ op://clankers/discord/password }}

# ── 1Password service account ──────────────────────────────────────
# Lets skills running in the openclaw container fetch any secret via
# `op read 'vault/item/field'` without an interactive signin.
OP_SERVICE_ACCOUNT_TOKEN={{ op://Private/jpbajz2zk4hzwstedcq7btk64y/mn545wasirie5xyxqlbvpscx5m }}

# ── gateway + browser tokens ───────────────────────────────────────
# Reuse the existing clankers/local-service password for all three. The CDP token
# here must match openclaw.json's ${OPENCLAW_BROWSER_CDP_AUTH_TOKEN} reference —
# both resolve from this same env var, so they stay in sync automatically.
OPENCLAW_GATEWAY_TOKEN={{ op://clankers/local-service/password }}
OPENCLAW_BROWSER_CDP_AUTH_TOKEN={{ op://clankers/local-service/password }}
OPENCLAW_BROWSER_NOVNC_PASSWORD={{ op://clankers/local-service/password }}
